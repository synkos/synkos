templates/backend/pnpm-lock.yaml

# Environment files
.env
.env.local
.env.*.local

# Editor & OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# Test coverage
coverage/
.nyc_output/

# Temp
.tmp/
temp/

# Turbo (if added later)

# Changesets — track .md files so CI can detect pending releases
