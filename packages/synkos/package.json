{
  "name": "synkos",
  "version": "0.3.1",
  "description": "Synkos frontend framework core (Quasar + Capacitor)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "synkos": "./dist/bin.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "vue": "^3.0.0",
    "vue-router": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "synkos",
    "framework",
    "frontend",
    "quasar",
    "vue",
    "capacitor"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  }
}
