NODE_ENV=development
PORT={{API_PORT}}
APP_NAME={{PROJECT_NAME}}
MONGODB_URI=mongodb://localhost:27017/{{PROJECT_NAME}}

# Auth — generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=change_me_at_least_32_chars_long_access_secret
JWT_REFRESH_SECRET=change_me_at_least_32_chars_long_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=30

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Apple Sign-In (get from Apple Developer Portal)
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_CLIENT_ID={{BUNDLE_ID}}

# CORS (comma-separated origins, or * for development)
CORS_ORIGINS=*

# Global rate limiter
# RATE_LIMIT_WINDOW_MS=900000   # 15 minutes (default)
# RATE_LIMIT_MAX=200            # requests per window (default)
# RATE_LIMIT_SKIP_DEV=true      # skip in development (default)

# ── Optional adapters ─────────────────────────────────────────────────────────
# Uncomment and fill in as needed. Core gracefully degrades without them.

# Email delivery (Resend — resend.com)
# RESEND_API_KEY=re_your_api_key_here
# RESEND_FROM=no-reply@yourdomain.com
# RESEND_FROM_DEV=no-reply@yourdomain.com
# RESEND_TEST_TO=you@email.com

# File storage (Cloudflare R2)
# R2_ACCOUNT_ID=your_account_id
# R2_ACCESS_KEY_ID=your_access_key_id
# R2_SECRET_ACCESS_KEY=your_secret_access_key
# R2_BUCKET=your-bucket-name
# R2_PUBLIC_BASE_URL=https://assets.yourdomain.com

# Apple Push Notifications (APNs)
# APNS_KEY_P8="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
# APNS_KEY_ID=XXXXXXXXX
# APNS_TEAM_ID=XXXXXXXXX
# APNS_BUNDLE_ID={{BUNDLE_ID}}

# Redis (queue + cache — BullMQ)
# REDIS_URL=redis://localhost:6379
