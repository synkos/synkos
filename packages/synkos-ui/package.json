{
  "name": "@synkos/ui",
  "version": "0.2.0",
  "description": "Synkos component library (Vue 3 + Quasar)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/synkos-ui.js"
    },
    "./styles": "./dist/style.css",
    "./variables.scss": "./src/styles/variables.scss"
  },
  "module": "./dist/synkos-ui.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "src/styles/variables.scss"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "quasar": "^2.0.0",
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "sass": "^1.87.0",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.10"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "synkos",
    "ui",
    "components",
    "vue",
    "quasar"
  ]
}
