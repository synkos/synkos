VITE_API_URL=http://localhost:{{API_PORT}}/api/v1

# Google Sign-In (get from Google Cloud Console)
VITE_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
VITE_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Apple Sign-In (get from Apple Developer Portal)
VITE_APPLE_CLIENT_ID={{BUNDLE_ID}}
VITE_APPLE_REDIRECT_URI=https://example.com/auth/apple/callback
